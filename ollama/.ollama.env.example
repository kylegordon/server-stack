# Ollama WebUI Environment Variables - EXAMPLE
# Copy this file to .ollama.env and update with real values

# Ollama server configuration
OLLAMA_BASE_URLS=http://host.docker.internal:7869

# WebUI configuration
ENV=dev
WEBUI_AUTH=False
WEBUI_NAME=Your AI Assistant
WEBUI_URL=http://localhost:8080

# Security: Generate a random secret key
WEBUI_SECRET_KEY=generate_secure_random_secret_key_here