# Infisical Environment Variables - EXAMPLE
# Copy this file to .env and update with real values

# PostgreSQL credentials
POSTGRES_USER=infisical
POSTGRES_PASSWORD=your_postgres_password_here

# Database connection URI (uses the postgres service name above)
DB_CONNECTION_URI=postgresql://infisical:your_postgres_password_here@infisical-db/infisical

# Redis connection URI (uses the redis service name above)
REDIS_URL=redis://infisical-redis:6379

# Encryption key - generate with: openssl rand -hex 16
ENCRYPTION_KEY=your_32_char_hex_encryption_key_here

# Auth secret (JWT signing) - generate with: openssl rand -base64 32
AUTH_SECRET=your_base64_auth_secret_here

# Site URL - must match Traefik routing
SITE_URL=https://infisical.viewpoint.house
