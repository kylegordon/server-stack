# 🦎 KOMODO CONFIGURATION 🦎

# Database Credentials
KOMODO_DB_USERNAME=komodo
KOMODO_DB_PASSWORD=changeme_secure_password

# Core Configuration
KOMODO_HOST=https://komodo.viewpoint.house
KOMODO_TITLE=Komodo

# First Server Connection
# Using local Periphery container
KOMODO_FIRST_SERVER=http://periphery:8120
KOMODO_FIRST_SERVER_NAME=homeauto
# Or connect to external Periphery:
# KOMODO_FIRST_SERVER=http://172.24.32.13:8120

# Monitoring Intervals
# Options: 1-sec, 5-sec, 15-sec, 1-min, 5-min, 15-min
KOMODO_MONITORING_INTERVAL=15-sec
# Options: 15-min, 1-hr, 2-hr, 6-hr, 12-hr, 1-day
KOMODO_RESOURCE_POLL_INTERVAL=1-hr

# Security Secrets (CHANGE THESE!)
# Generate random secrets using: openssl rand -hex 32
# Note: KOMODO_PASSKEY is used by both Core and Periphery for authentication
KOMODO_PASSKEY=change_this_random_passkey
KOMODO_WEBHOOK_SECRET=change_this_random_webhook_secret
KOMODO_JWT_SECRET=change_this_random_jwt_secret
# Options: 1-hr, 12-hr, 1-day, 3-day, 1-wk, 2-wk
KOMODO_JWT_TTL=1-day

# Authentication
KOMODO_LOCAL_AUTH=true
KOMODO_INIT_ADMIN_USERNAME=admin
KOMODO_INIT_ADMIN_PASSWORD=changeme_admin_password
KOMODO_DISABLE_USER_REGISTRATION=false
KOMODO_ENABLE_NEW_USERS=false

# Timezone
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Europe/London

# Periphery Agent Configuration
# The Periphery agent uses KOMODO_PASSKEY for authentication (set above)
# You can add additional passkeys here as a comma-separated list if needed
# PERIPHERY_PASSKEYS=${KOMODO_PASSKEY},additional_passkey_here
PERIPHERY_DISABLE_TERMINALS=false
