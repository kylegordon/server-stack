# Ultrafeeder Configuration
# Copy this file to .env and fill in your values

# Timezone
FEEDER_TZ=Europe/London

# Location coordinates
FEEDER_LAT=55.7807302
FEEDER_LONG=-4.4716651
FEEDER_ALT_M=217

# Feeder identification
FEEDER_NAME=my_sitename
MULTIFEEDER_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SDR Device configuration
ADSB_SDR_SERIAL=00001090
ADSB_SDR_PPM=0

# HeyWhatsThat coverage map configuration
FEEDER_HEYWHATSTHAT_ID=
FEEDER_HEYWHATSTHAT_ALTS=

# InfluxDB configuration (optional)
INFLUXDBURL=http://influxdb:8086
INFLUXDB_V2_TOKEN=your_token_here
INFLUXDB_V2_BUCKET=ultrafeeder
INFLUXDB_V2_ORG=your_org

# ADSBExchange UUID (optional, uncomment ULTRAFEEDER_CONFIG lines if using)
# ADSBX_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
